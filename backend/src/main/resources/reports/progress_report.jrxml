<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
  name="ProgressReport" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
  resourceBundle="reports.report_labels">

  <parameter name="studentName" class="java.lang.String"/>
  <parameter name="professionalName" class="java.lang.String"/>
  <parameter name="issuedOn" class="java.lang.String"/>
  <parameter name="initialDate" class="java.lang.String"/>
  <parameter name="currentDate" class="java.lang.String"/>

  <field name="metric" class="java.lang.String"/>
  <field name="initial" class="java.lang.String"/>
  <field name="current" class="java.lang.String"/>
  <field name="difference" class="java.lang.String"/>
  <field name="improved" class="java.lang.Boolean"/>

  <title>
    <band height="120">
      <!-- Dark header background -->
      <rectangle>
        <reportElement x="0" y="0" width="555" height="76" backcolor="#111827" forecolor="#111827"/>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>
      <!-- P logo circle -->
      <ellipse>
        <reportElement x="20" y="16" width="42" height="42" backcolor="#7C3AED" forecolor="#7C3AED"/>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </ellipse>
      <!-- P letter -->
      <staticText>
        <reportElement x="20" y="16" width="42" height="42" forecolor="#FFFFFF"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font size="22" isBold="true" fontName="SansSerif"/>
        </textElement>
        <text><![CDATA[P]]></text>
      </staticText>
      <!-- PROGRESSOR brand -->
      <staticText>
        <reportElement x="72" y="12" width="200" height="26" forecolor="#FFFFFF"/>
        <textElement verticalAlignment="Middle">
          <font size="17" isBold="true" fontName="SansSerif"/>
        </textElement>
        <text><![CDATA[PROGRESSOR]]></text>
      </staticText>
      <!-- Subtitle (i18n) -->
      <textField>
        <reportElement x="72" y="40" width="200" height="24" forecolor="#9CA3AF"/>
        <textElement verticalAlignment="Middle">
          <font size="9" fontName="SansSerif"/>
        </textElement>
        <textFieldExpression><![CDATA[$R{report.progress.subtitle}]]></textFieldExpression>
      </textField>
      <!-- Report title (right, i18n) -->
      <textField>
        <reportElement x="280" y="20" width="255" height="30" forecolor="#FFFFFF"/>
        <textElement textAlignment="Right" verticalAlignment="Middle">
          <font size="15" isBold="true" fontName="SansSerif"/>
        </textElement>
        <textFieldExpression><![CDATA[$R{report.progress.title}]]></textFieldExpression>
      </textField>

      <!-- Metadata row background -->
      <rectangle>
        <reportElement x="0" y="76" width="555" height="44" backcolor="#F9FAFB" forecolor="#F9FAFB"/>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>
      <!-- STUDENT label -->
      <textField>
        <reportElement x="8" y="80" width="180" height="12" forecolor="#9CA3AF"/>
        <textElement><font size="7" isBold="true" fontName="SansSerif"/></textElement>
        <textFieldExpression><![CDATA[$R{report.label.student}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="8" y="93" width="180" height="24" forecolor="#111827"/>
        <textElement verticalAlignment="Middle">
          <font size="10" isBold="true" fontName="SansSerif"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{studentName}]]></textFieldExpression>
      </textField>
      <!-- PROFESSIONAL label -->
      <textField>
        <reportElement x="200" y="80" width="180" height="12" forecolor="#9CA3AF"/>
        <textElement><font size="7" isBold="true" fontName="SansSerif"/></textElement>
        <textFieldExpression><![CDATA[$R{report.label.professional}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="200" y="93" width="180" height="24" forecolor="#111827"/>
        <textElement verticalAlignment="Middle">
          <font size="10" isBold="true" fontName="SansSerif"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{professionalName}]]></textFieldExpression>
      </textField>
      <!-- ISSUED ON label -->
      <textField>
        <reportElement x="430" y="80" width="125" height="12" forecolor="#9CA3AF"/>
        <textElement textAlignment="Right"><font size="7" isBold="true" fontName="SansSerif"/></textElement>
        <textFieldExpression><![CDATA[$R{report.label.issued}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="430" y="93" width="125" height="24" forecolor="#111827"/>
        <textElement textAlignment="Right" verticalAlignment="Middle">
          <font size="10" isBold="true" fontName="SansSerif"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{issuedOn}]]></textFieldExpression>
      </textField>
    </band>
  </title>

  <columnHeader>
    <band height="28">
      <rectangle>
        <reportElement x="0" y="0" width="555" height="28" backcolor="#1F2937" forecolor="#1F2937"/>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>
      <textField>
        <reportElement x="8" y="0" width="192" height="28" forecolor="#E5E7EB"/>
        <textElement verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement>
        <textFieldExpression><![CDATA[$R{report.col.metric}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="200" y="0" width="100" height="28" forecolor="#E5E7EB"/>
        <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement>
        <textFieldExpression><![CDATA[$R{report.col.initial}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="300" y="0" width="100" height="28" forecolor="#E5E7EB"/>
        <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement>
        <textFieldExpression><![CDATA[$R{report.col.current}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="400" y="0" width="155" height="28" forecolor="#E5E7EB"/>
        <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true" fontName="SansSerif"/></textElement>
        <textFieldExpression><![CDATA[$R{report.col.difference}]]></textFieldExpression>
      </textField>
    </band>
  </columnHeader>

  <detail>
    <band height="32">
      <rectangle>
        <reportElement x="0" y="0" width="555" height="32" backcolor="#F9FAFB" forecolor="#F9FAFB">
          <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
        </reportElement>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>
      <textField isBlankWhenNull="true">
        <reportElement x="8" y="0" width="192" height="32" forecolor="#111827"/>
        <textElement verticalAlignment="Middle">
          <font size="9" isBold="true" fontName="SansSerif"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{metric}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="200" y="0" width="100" height="32" forecolor="#374151"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font size="9" fontName="SansSerif"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{initial}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="300" y="0" width="100" height="32" forecolor="#374151"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font size="9" fontName="SansSerif"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{current}]]></textFieldExpression>
      </textField>
      <!-- Improved (green) -->
      <textField isBlankWhenNull="true">
        <reportElement x="400" y="0" width="155" height="32" forecolor="#16A34A">
          <printWhenExpression><![CDATA[Boolean.TRUE.equals($F{improved})]]></printWhenExpression>
        </reportElement>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font size="9" isBold="true" fontName="SansSerif"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{difference}]]></textFieldExpression>
      </textField>
      <!-- Worsened (red) -->
      <textField isBlankWhenNull="true">
        <reportElement x="400" y="0" width="155" height="32" forecolor="#DC2626">
          <printWhenExpression><![CDATA[Boolean.FALSE.equals($F{improved})]]></printWhenExpression>
        </reportElement>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font size="9" isBold="true" fontName="SansSerif"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{difference}]]></textFieldExpression>
      </textField>
      <!-- Neutral (gray) -->
      <textField isBlankWhenNull="true">
        <reportElement x="400" y="0" width="155" height="32" forecolor="#6B7280">
          <printWhenExpression><![CDATA[$F{improved} == null]]></printWhenExpression>
        </reportElement>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font size="9" fontName="SansSerif"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{difference}]]></textFieldExpression>
      </textField>
    </band>
  </detail>

  <pageFooter>
    <band height="20">
      <line>
        <reportElement x="0" y="0" width="555" height="1" forecolor="#E5E7EB"/>
      </line>
      <textField>
        <reportElement x="0" y="4" width="340" height="16" forecolor="#9CA3AF"/>
        <textElement verticalAlignment="Middle">
          <font size="7" fontName="SansSerif"/>
        </textElement>
        <textFieldExpression><![CDATA[$R{report.footer}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="340" y="4" width="215" height="16" forecolor="#9CA3AF"/>
        <textElement textAlignment="Right" verticalAlignment="Middle">
          <font size="7" fontName="SansSerif"/>
        </textElement>
        <textFieldExpression><![CDATA[$R{report.page} + " " + $V{PAGE_NUMBER}]]></textFieldExpression>
      </textField>
    </band>
  </pageFooter>
</jasperReport>
