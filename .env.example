# ── Database ──────────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/progressorv1
SPRING_DATASOURCE_USERNAME=progressorv1
SPRING_DATASOURCE_PASSWORD=progressorv1

# ── USDA FoodData Central API ─────────────────────────────────────────────────
USDA_API_KEY=your_usda_api_key_here

# ── AES-256 Encryption Key ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must be exactly 64 hex characters (32 bytes / 256 bits).
# WARNING: changing this key invalidates ALL encrypted data in the database.
ENCRYPTION_KEY=replace_with_32_random_bytes_as_64_hex_chars
